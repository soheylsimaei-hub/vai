---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
---
<Base
  title="About VAI"
  description="Veterinary Academy International is the veterinary education arm of Academia Europa, dedicated to structured postgraduate veterinary education."
>
  <PageHero
    eyebrow="About VAI"
    title="The Veterinary Education Arm of Academia Europa."
    lede="Structured postgraduate veterinary education for experienced practitioners."
  />

  <Section eyebrow="Our Purpose" title="From clinical competence to clinical mastery.">
    <div class="prose-editorial max-w-5xl">
      <p>VAI exists to provide veterinarians and veterinary teams with structured postgraduate education built around deliberate progression, evidence-informed teaching, and case-based clinical reasoning. Its work is shaped by the conviction that experienced practitioners deserve more than fragmented continuing education.</p>
    </div>
  </Section>

  <Section eyebrow="Our Place" title="Veterinary education by Academia Europa." tone="ivory">
    <div class="prose-editorial max-w-5xl">
      <p>VAI is the veterinary faculty within Academia Europa, a European institution for structured postgraduate professional education. Academia Europa is operated by Solex Education Unipessoal LDA, Portugal.</p>
      <div class="mt-8">
        <a href="https://academiaeuropa.com" rel="noopener" class="btn">Visit Academia Europa</a>
      </div>
    </div>
  </Section>

  <Section eyebrow="Who We Serve" title="Built for experienced veterinary professionals.">
    <ul class="grid md:grid-cols-2 gap-4 max-w-5xl">
      {[
        'Veterinarians with three or more years of practice',
        'Veterinary specialists and surgeons',
        'Practice owners and clinical leaders',
        'Veterinary educators',
        'Veterinary teams seeking structured CPD/CE',
        'Practitioners pursuing professional sustainability and longevity',
      ].map((a) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-champagne text-xs">—</span><span>{a}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Leadership" title="Founder-led. Academically collaborative." tone="ivory">
    <div class="grid md:grid-cols-12 gap-10 md:gap-14 items-start max-w-5xl">
      <div class="md:col-span-4">
        <figure class="relative">
          <div class="aspect-[3/4] overflow-hidden bg-platinum-soft">
            <img
              src="/founder-portrait.png"
              alt="Dr. Soheyl Simaei, Founder & Academic Director of Veterinary Academy International"
              loading="lazy"
              decoding="async"
              class="block w-full h-full object-cover"
              style="object-position: 50% 20%;"
            />
          </div>
          <div class="absolute -bottom-px left-0 w-12 h-px bg-champagne"></div>
        </figure>
      </div>
      <div class="md:col-span-8">
        <div class="font-serif text-3xl md:text-4xl text-navy-deep leading-tight">Dr. Soheyl Simaei</div>
        <div class="eyebrow mt-3 mb-6">Founder &amp; Academic Director</div>
        <p class="text-graphite leading-relaxed text-lg">
          Veterinarian with more than two decades of clinical practice.<br />
          Founder of Academia Europa.
        </p>
        <p class="text-graphite leading-relaxed mt-6">VAI was established under the leadership of Dr. Soheyl Simaei and is being developed with experienced veterinary professionals, educators, and subject-matter experts. Its purpose is to bring structure, academic discipline, and clinical relevance to postgraduate veterinary education.</p>
        <div class="mt-8">
          <a href="/about/leadership" class="inline-block text-sm tracking-[0.14em] uppercase text-navy hover:text-champagne">Read the leadership note →</a>
        </div>
      </div>
    </div>
  </Section>
</Base>
