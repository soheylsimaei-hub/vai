---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';

const offered = [
  'A serious institutional home for your teaching',
  'Premium production standards',
  'Structured course design support',
  'Academic documentation that protects your reputation',
  'International professional visibility',
  'Long-term collaborative relationships',
];
const expected = [
  'Relevant veterinary qualifications and demonstrable experience',
  'Evidence-based, ethically grounded teaching',
  'Clarity, precision, and respect for clinical uncertainty',
  'Willingness to work within a structured course design process',
  'Honest grading of evidence levels in your content',
];
---
<Base
  title="Teach with VAI · Faculty"
  description="VAI invites experienced veterinary professionals, educators, academic contributors, and field-specific experts to contribute to structured postgraduate learning."
>
  <PageHero
    eyebrow="Faculty"
    title="Teach Within a Structured Veterinary Academy."
    lede="VAI invites experienced veterinary professionals, educators, academic contributors, and field-specific experts to contribute to structured postgraduate learning."
  />

  <Section eyebrow="The Invitation">
    <div class="prose-editorial max-w-5xl">
      <p>Our model supports expert knowledge with academic documentation, production quality, and professional respect. Faculty join a long-term institution, not a course marketplace.</p>
    </div>
  </Section>

  <Section eyebrow="What We Offer Faculty" tone="ivory">
    <ul class="grid md:grid-cols-2 gap-4 max-w-5xl">
      {offered.map((o) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-champagne text-xs">—</span><span>{o}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="What We Ask of Faculty">
    <ul class="grid md:grid-cols-2 gap-4 max-w-5xl">
      {expected.map((e) => (
        <li class="flex gap-3 items-baseline text-graphite leading-relaxed">
          <span class="text-champagne text-xs">—</span><span>{e}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Faculty Standards" title="What we ask of every contributor." tone="ivory">
    <ul class="grid md:grid-cols-2 gap-4 max-w-5xl">
      {[
        ['Relevant qualifications', 'Veterinary or scientific qualifications appropriate to the subject taught.'],
        ['Demonstrable experience', 'Clinical, academic, or research experience that supports the teaching.'],
        ['Evidence-based teaching', 'Use of the VAI evidence hierarchy, with claims appropriately labelled.'],
        ['Ethical communication', 'No exaggerated outcomes; respect for clinical uncertainty.'],
        ['Declared interests', 'Conflict-of-interest disclosure submitted before publication.'],
        ['Structured collaboration', 'Willingness to work within VAI\'s course design and review process.'],
      ].map(([t, d]) => (
        <li>
          <div class="font-serif text-lg text-navy-deep mb-1">{t}</div>
          <div class="text-graphite leading-relaxed text-sm">{d}</div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Teaching Across Formats" title="Faculty may contribute across multiple formats.">
    <div class="prose-editorial max-w-5xl">
      <p>Faculty contributors may participate in recorded courses, live online teaching, case discussions, hybrid programmes, or selected in-person educational experiences. VAI's role is to support expert knowledge with structured course design, academic documentation, and production standards appropriate to each format.</p>
      <div class="mt-6">
        <a href="/contact" class="inline-block text-sm tracking-[0.14em] uppercase text-navy hover:text-champagne">Discuss Teaching With VAI →</a>
      </div>
    </div>
  </Section>

  <Section eyebrow="Process" title="From enquiry to publication." tone="ivory">
    <ol class="max-w-4xl divide-y divide-platinum">
      {[
        { t: 'Enquiry', d: 'Submit qualifications, experience, and area of teaching interest.' },
        { t: 'Initial review', d: 'Suitability assessment by the academy.' },
        { t: 'Scoping conversation', d: 'Define topic, level, structure, and outcomes.' },
        { t: 'Course design', d: 'Collaborative curriculum development with academic support.' },
        { t: 'Production', d: 'Recording, editing, and final assembly.' },
        { t: 'Academic review', d: 'Final review against our standards before publication.' },
        { t: 'Publication & ongoing care', d: 'Versioning, updates, and faculty support.' },
      ].map((s, i) => (
        <li class="py-6 grid md:grid-cols-12 gap-4">
          <div class="md:col-span-1 font-serif text-navy-deep text-sm tracking-[0.3em]">0{i + 1}</div>
          <div class="md:col-span-4 font-serif text-xl text-navy-deep">{s.t}</div>
          <div class="md:col-span-7 text-graphite leading-relaxed">{s.d}</div>
        </li>
      ))}
    </ol>
    <div class="mt-12">
      <a href="/contact" class="btn">Apply to Teach</a>
    </div>
  </Section>
</Base>
