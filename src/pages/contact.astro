---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';

const pathways = [
  {
    t: 'VAI Enquiries',
    e: 'vai@vai.vet',
    d: 'For course interest, programme questions, learner enquiries, and general VAI communication.',
  },
  {
    t: 'Academic & CPD/CE Review',
    e: 'academic@academiaeuropa.com',
    d: 'For academic review, programme documentation, CPD/CE-related enquiries, and institutional review.',
  },
  {
    t: 'Partnerships & Faculty Collaboration',
    e: 'partnerships@academiaeuropa.com',
    d: 'For faculty collaboration, programme co-development, institutional partnerships, and professional association dialogue.',
  },
];
---
<Base
  title="Contact VAI"
  description="Programme, academic review, and partnership enquiries for Veterinary Academy International."
>
  <PageHero
    eyebrow="Contact"
    title="Contact VAI."
    lede="For programme enquiries, academic review, or faculty collaboration, please use the appropriate pathway below."
  />

  <Section eyebrow="Send an Enquiry" title="Use the form below, or reach the relevant office directly.">
    <ContactForm />
  </Section>

  <Section eyebrow="Direct Pathways" title="Reach the appropriate office directly." tone="ivory">
    <ul class="max-w-5xl border-t border-platinum">
      {pathways.map((p) => (
        <li class="grid md:grid-cols-12 gap-6 md:gap-10 items-baseline py-8 border-b border-platinum">
          <div class="md:col-span-4">
            <div class="eyebrow">{p.t}</div>
          </div>
          <div class="md:col-span-8 text-graphite leading-relaxed text-[15px]">
            {p.d}
            <a href={`mailto:${p.e}`} class="block mt-3 text-navy-deep hover:text-champagne transition-colors">{p.e}</a>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Relationship to Academia Europa">
    <div class="prose-editorial max-w-5xl">
      <p>As a specialised academy of <a href="https://academiaeuropa.com" rel="noopener" class="text-navy-deep underline decoration-champagne underline-offset-4">Academia Europa</a>, VAI coordinates academic review and partnership enquiries through the institutional office of Academia Europa. Programme-level and learner enquiries are handled directly by VAI.</p>
    </div>
  </Section>

  <Section eyebrow="Institutional Information" tone="ivory">
    <div class="prose-editorial max-w-5xl">
      <p>Veterinary Academy International is a specialised academy of Academia Europa, operated by <strong class="text-navy-deep font-medium">Solex Education Unipessoal LDA</strong>, registered in Portugal.</p>
    </div>
  </Section>
</Base>
