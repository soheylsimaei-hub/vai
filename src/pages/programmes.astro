---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';

const directions = [
  {
    n: '01',
    name: 'Veterinary Longevity',
    flagship: true,
    short: "Veterinary Longevity is VAI's first flagship educational direction, focused on animal healthspan, aging biology, early detection, preventive strategies, and responsible clinical integration. Developed within VAI, with a dedicated platform at VeterinaryLongevity.com.",
    audience: 'Veterinarians, clinical directors, practice owners, educators.',
    status: 'Flagship direction with dedicated platform.',
    external: 'https://www.veterinarylongevity.com',
    href: '/programmes/foundations-veterinary-longevity',
    relatedLabel: 'Foundations of Veterinary Longevity →',
  },
  {
    n: '02',
    name: 'Clinical Mastery',
    short: 'Clinical Mastery programmes are designed to strengthen diagnostic reasoning, case interpretation, therapeutic planning, and practical clinical decision-making in everyday veterinary practice.',
    audience: 'Veterinarians with three or more years of practice.',
    status: 'In development.',
    examples: [
      'Advanced Dermatology Case Reasoning',
      'Internal Medicine Decision-Making',
      'Diagnostic Reasoning in Small Animal Practice',
      'Evidence-Based Therapeutic Planning',
      'Case-Based Clinical Problem Solving',
    ],
  },
  {
    n: '03',
    name: 'Practice Leadership',
    short: 'Practice Leadership programmes support veterinarians and clinical leaders who are responsible for medical standards, team development, client communication, workflow quality, and sustainable clinical operations.',
    audience: 'Practice owners, clinical leads, senior associates.',
    status: 'In development.',
    examples: [
      'Clinical Director Foundations',
      'Building Medical Standards in Practice',
      'Leading Veterinary Teams with Structure',
      'Client Communication and Compliance Leadership',
      'Sustainable Veterinary Practice Management',
    ],
  },
  {
    n: '04',
    name: 'Veterinary Team Development',
    short: 'Veterinary Team Development programmes are designed to support the wider veterinary team through structured training in communication, client journey, clinical support, workflow, and professional standards.',
    audience: 'Veterinary nurses, receptionists, assistants, client care teams.',
    status: 'In development.',
    examples: [
      'Reception Excellence in Veterinary Practice',
      'Veterinary Nurse Communication',
      'Client Journey and Compliance',
      'Assistant Training for Clinical Workflow',
      'Team Standards for Modern Veterinary Clinics',
    ],
  },
  {
    n: '05',
    name: 'Future Programmes',
    short: 'Future VAI programmes will be developed in response to professional need, faculty expertise, clinical relevance, and academic review readiness. New areas may include advanced clinical disciplines, communication, leadership, technology, and emerging fields in veterinary medicine.',
    audience: null,
    status: 'Forthcoming.',
    examples: [
      'Veterinary Artificial Intelligence and Digital Tools',
      'Advanced Client Communication',
      'Veterinary Ethics and Professional Responsibility',
      'Preventive Medicine and Healthspan',
      'Clinical Quality Systems',
      'Veterinary Education and Mentorship',
    ],
  },
];
---
<Base
  title="Programmes · VAI"
  description="Five programme directions for veterinarians under VAI's structured postgraduate education framework."
>
  <PageHero
    eyebrow="Programmes"
    title="Structured Veterinary Education, by Direction."
    lede="VAI organises its programmes around five educational directions. Each is developed within the academic standards of Academia Europa."
  />

  <Section>
    <ul class="space-y-14 max-w-5xl">
      {directions.map((d) => (
        <li class="border-t border-platinum pt-10">
          <div class="grid md:grid-cols-12 gap-6">
            <div class="md:col-span-2">
              <div class="font-serif text-navy-deep text-xs tracking-[0.3em] mb-3">{d.n}</div>
              {d.flagship && <div class="eyebrow text-champagne-soft">Flagship</div>}
            </div>
            <div class="md:col-span-10">
              <h2 class="font-serif text-2xl md:text-3xl text-navy-deep mb-3">{d.name}</h2>
              <p class="text-graphite leading-relaxed mb-4 max-w-5xl">{d.short}</p>
              {d.audience && (
                <p class="text-sm text-muted mb-2"><span class="eyebrow mr-2">Audience</span>{d.audience}</p>
              )}
              <p class="text-sm text-navy-deep mb-5"><span class="eyebrow mr-2">Status</span>{d.status}</p>

              {d.examples && (
                <div class="mb-6">
                  <div class="eyebrow mb-3">Example Future Courses</div>
                  <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-2 max-w-5xl">
                    {d.examples.map((ex) => (
                      <li class="flex gap-3 items-baseline text-graphite text-[15px] leading-relaxed">
                        <span class="text-champagne text-xs">—</span><span>{ex}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {d.external && (
                <div class="flex flex-wrap gap-4 items-baseline">
                  <a href={d.external} rel="noopener" target="_blank" class="btn">Visit Veterinary Longevity ↗</a>
                  {d.href && (
                    <a href={d.href} class="inline-block text-sm tracking-[0.14em] uppercase text-navy hover:text-champagne">{d.relatedLabel ?? 'Explore →'}</a>
                  )}
                </div>
              )}
              {!d.external && d.href && (
                <a href={d.href} class="inline-block text-sm tracking-[0.14em] uppercase text-navy hover:text-champagne">Explore the programme →</a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Programme Delivery Formats" title="Format selected for the educational purpose." tone="ivory">
    <div class="prose-editorial max-w-5xl mb-12">
      <p>VAI programmes may be delivered through different learning formats depending on the subject, faculty, learning objectives, and professional requirements. The aim is to match the format to the educational purpose, not to force every topic into the same model.</p>
    </div>
    <ul class="grid md:grid-cols-2 gap-8 max-w-5xl">
      {[
        {
          n: '01',
          t: 'Self-Paced Online Courses',
          d: 'Structured recorded lessons supported by downloadable frameworks, guided learning materials, review questions, and certificate criteria. Designed for professionals who need flexibility without losing academic structure.',
        },
        {
          n: '02',
          t: 'Live Online Teaching',
          d: 'Faculty-led online sessions that may include case discussions, Q&A, clinical reasoning exercises, or interactive teaching where the subject benefits from real-time engagement.',
        },
        {
          n: '03',
          t: 'Hybrid Programmes',
          d: 'Programmes that combine structured online learning with live teaching, discussion, or supervised educational components, allowing deeper progression and stronger learner engagement.',
        },
        {
          n: '04',
          t: 'In-Person Courses & Workshops',
          d: 'Selected workshops, intensives, masterclasses, or professional events may be delivered in person where direct interaction, practical demonstration, or focused group learning adds educational value.',
        },
      ].map((f) => (
        <li class="border-l-2 border-teal pl-6 py-1">
          <div class="font-serif text-teal text-xs tracking-[0.3em] mb-2">{f.n}</div>
          <h3 class="font-serif text-xl text-navy-deep mb-3">{f.t}</h3>
          <p class="text-graphite leading-relaxed text-[15px]">{f.d}</p>
        </li>
      ))}
    </ul>
    <p class="mt-10 text-sm text-muted max-w-3xl leading-relaxed">
      Format availability per programme is stated on the corresponding programme page. Future editions may introduce additional formats where they support the learning objectives.
    </p>
  </Section>

  <Section eyebrow="Academic Documentation & Programme Assets" title="Structured documentation behind every programme.">
    <div class="prose-editorial max-w-5xl mb-12">
      <p>VAI programmes are supported by structured academic documentation, including learning objectives, module outlines, evidence-level distinctions, assessment criteria, certificate requirements, and versioned review materials.</p>
    </div>
    <ul class="grid md:grid-cols-2 gap-x-10 gap-y-10 max-w-5xl">
      {[
        {
          n: '01',
          t: 'Sample Certificate Preview',
          d: 'Preview the structure and wording of VAI certificates of completion.',
          href: '/programmes/foundations-veterinary-longevity',
          cta: 'View on the flagship programme →',
        },
        {
          n: '02',
          t: 'Evidence Hierarchy',
          d: 'Understand how VAI distinguishes established knowledge from emerging evidence and future-facing expert hypothesis.',
          href: '/academic-standards',
          cta: 'View the four levels →',
        },
        {
          n: '03',
          t: 'Module Preview',
          d: 'Explore a sample module structure, including learning objectives, subtopics, clinical relevance, and assessment style.',
          href: '/programmes/foundations-veterinary-longevity/module-1',
          cta: 'Preview Module 1 →',
        },
        {
          n: '04',
          t: 'Programme Academic Pack',
          d: 'Selected programmes may include an academic pack with course rationale, module structure, assessment approach, certificate wording, evidence framework, and review status. In preparation.',
        },
        {
          n: '05',
          t: 'Programme Documentation Checklist',
          d: 'Review the academic elements used to structure VAI programmes, including learning objectives, faculty documentation, references, assessment method, and certificate criteria.',
          href: '/programmes/foundations-veterinary-longevity',
          cta: 'View on the flagship programme →',
        },
      ].map((a) => (
        <li class="border-l-2 border-teal pl-6 py-1">
          <div class="font-serif text-teal text-xs tracking-[0.3em] mb-2">{a.n}</div>
          <h3 class="font-serif text-xl text-navy-deep mb-3">{a.t}</h3>
          <p class="text-graphite leading-relaxed text-[15px] mb-3">{a.d}</p>
          {a.href && (
            <a href={a.href} class="inline-block text-sm tracking-[0.14em] uppercase text-navy hover:text-teal-hover">{a.cta}</a>
          )}
        </li>
      ))}
    </ul>
    <p class="mt-10 text-sm text-muted max-w-3xl leading-relaxed">
      Additional academic documentation will be added as programmes are finalised, with downloadable versions available where applicable.
    </p>
  </Section>

  <Section eyebrow="Faculty & Reviewers" title="Announcements forthcoming." tone="ivory">
    <div class="prose-editorial max-w-5xl">
      <p>Faculty and academic contributors will be announced as programmes are finalised. Educators interested in contributing to a future programme direction are welcome to enquire.</p>
      <div class="mt-8">
        <a href="/faculty" class="btn">Join our Faculty</a>
      </div>
    </div>
  </Section>

  <Section eyebrow="Engage">
    <div class="prose-editorial max-w-5xl">
      <p>To be notified when programmes open for registration, or to discuss faculty participation, please register your interest.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/contact" class="btn">Register Interest</a>
        <a href="/faculty" class="btn">Join our Faculty</a>
      </div>
    </div>
  </Section>
</Base>
