---
const levels = [
  { l: 'Level 1', t: 'Strong Clinical Evidence', d: 'Established, replicated, clinically accepted.' },
  { l: 'Level 2', t: 'Emerging Clinical Evidence', d: 'Early but credible clinical data.' },
  { l: 'Level 3', t: 'Preclinical or Mechanistic', d: 'Laboratory or translational; not yet clinical.' },
  { l: 'Level 4', t: 'Expert Hypothesis', d: 'Reasoned perspective; clearly labelled.' },
];
---
<div class="max-w-4xl mx-auto border-t border-platinum">
  {levels.map((lv) => (
    <div class="grid grid-cols-12 gap-6 items-baseline py-7 border-b border-platinum">
      <div class="col-span-12 md:col-span-2">
        <div class="eyebrow text-champagne">{lv.l}</div>
      </div>
      <div class="col-span-12 md:col-span-5">
        <div class="font-serif text-xl md:text-2xl text-navy-deep leading-tight">{lv.t}</div>
      </div>
      <div class="col-span-12 md:col-span-5">
        <div class="text-graphite leading-relaxed text-sm md:text-base">{lv.d}</div>
      </div>
    </div>
  ))}
</div>
