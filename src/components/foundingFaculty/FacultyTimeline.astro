---
const stages = [
  {
    title: 'Invitation',
    text: 'A personal introduction to VAI and an honest account of what Founding Faculty involves.',
    icon: 'M2 5h16v10H2z M2 5l8 6 8-6',
  },
  {
    title: 'Conversation',
    text: 'A direct conversation to understand your expertise and how it might be taught.',
    icon: 'M3 4h14v9H8l-5 4v-4H3z',
  },
  {
    title: 'Educational Design',
    text: 'We shape the clinical material into a structured, teachable curriculum together.',
    icon: 'M10 2l7 3.5v9L10 18l-7-3.5v-9z M10 2v16 M3 5.5l7 3.5 7-3.5',
  },
  {
    title: 'Filming',
    text: 'Professional production, on your schedule, with full technical and editorial support.',
    icon: 'M2 6h11v8H2z M13 9l5-3v8l-5-3z',
  },
  {
    title: 'Editing',
    text: 'Footage is shaped into a polished course, with your review at every stage.',
    icon: 'M6 4l8 12M14 4L6 16 M4 4a2 2 0 100 4 2 2 0 000-4zM4 12a2 2 0 100 4 2 2 0 000-4z',
  },
  {
    title: 'Faculty Review',
    text: 'Nothing is published until you have approved the final material.',
    icon: 'M2 10s3-6 8-6 8 6 8 6-3 6-8 6-8-6-8-6z M10 12a2 2 0 100-4 2 2 0 000 4z',
  },
  {
    title: 'Launch',
    text: 'Your course is introduced to VAI’s community of veterinary professionals.',
    icon: 'M10 2v12M10 2l4 4M10 2L6 6 M4 16h12',
  },
  {
    title: 'Long-term Partnership',
    text: 'An ongoing relationship, with updates, support, and shared academic stewardship.',
    icon: 'M6.5 10a3.5 3.5 0 110-.01M13.5 10a3.5 3.5 0 110-.01M10 10h0',
  },
];
---
<section class="bg-ivory">
  <div class="container-prose py-20 md:py-28">
    <div class="max-w-3xl mb-16 md:mb-20">
      <div class="eyebrow mb-6">Faculty Experience</div>
      <div class="rule-gold"></div>
    </div>

    <ol class="relative max-w-2xl mx-auto md:mx-0">
      <div class="absolute left-[19px] top-2 bottom-2 w-px bg-platinum" aria-hidden="true"></div>
      {stages.map((s, i) => (
        <li class="ff-timeline-item relative flex gap-6 pb-14 last:pb-0" style={`transition-delay: ${i * 60}ms`}>
          <span class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-navy bg-ivory text-navy">
            <svg viewBox="0 0 20 20" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={s.icon} />
            </svg>
          </span>
          <div class="pt-1.5">
            <h3 class="font-serif text-xl md:text-2xl text-navy-deep leading-snug">{s.title}</h3>
            <p class="mt-2 text-graphite leading-relaxed max-w-md">{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
<style>
  .ff-timeline-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 400ms ease, transform 400ms ease;
  }
  .ff-timeline-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .ff-timeline-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
<script>
  const items = document.querySelectorAll('.ff-timeline-item');
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    items.forEach((el) => el.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -10% 0px' }
    );
    items.forEach((el) => observer.observe(el));
  }
</script>
