---
interface Props {
  id: string;
  videoEmbedUrl?: string;
  posterSrc?: string;
}
const { id, videoEmbedUrl, posterSrc } = Astro.props;
---
<section id={id} class="bg-paper scroll-mt-10">
  <div class="container-prose py-16 md:py-24">
    <div class="mx-auto" style="max-width: 1100px;">
      {videoEmbedUrl ? (
        <div class="relative aspect-video overflow-hidden bg-navy-deep">
          <iframe
            src={videoEmbedUrl}
            title="A message from the Founder, Dr. Soheyl Simaei"
            class="absolute inset-0 h-full w-full"
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      ) : (
        <div class="heritage-frame relative aspect-video overflow-hidden flex items-center justify-center" style="background: linear-gradient(150deg, var(--color-navy-deep), var(--color-navy-soft) 65%, var(--color-navy-deep));">
          {posterSrc && (
            <img src={posterSrc} alt="" class="absolute inset-0 h-full w-full object-cover opacity-50" loading="lazy" decoding="async" />
          )}
          <div class="relative flex flex-col items-center gap-5 text-ivory">
            <span class="flex h-20 w-20 items-center justify-center rounded-full border border-ivory/40 bg-ivory/5 backdrop-blur-sm transition-colors">
              <svg viewBox="0 0 24 24" class="h-6 w-6 translate-x-0.5" fill="currentColor" aria-hidden="true">
                <path d="M8 5v14l11-7-11-7z" />
              </svg>
            </span>
            <span class="text-[11px] tracking-[0.22em] uppercase text-platinum">Founder Introduction</span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
