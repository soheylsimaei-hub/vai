---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/programmes', label: 'Programmes' },
  { href: '/academic-standards', label: 'Academic Standards' },
  { href: '/faculty', label: 'Faculty' },
  { href: '/cpd-ce-alignment', label: 'CPD/CE' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="border-b border-platinum-soft bg-paper">
  <!-- Top row: logo + tagline (centered on desktop, left on mobile) + mobile menu button -->
  <div class="container-prose flex items-center justify-between lg:justify-center py-6 lg:py-8">
    <a href="/" class="flex items-center gap-5">
      <span class="relative inline-block">
        <img
          src="/vai-logo.svg"
          alt="VAI · Veterinary Academy International"
          class="h-12 md:h-14 w-auto"
        />
        <span class="absolute top-0 -right-3 text-[10px] font-sans" style="color: #101114; line-height: 1;">™</span>
      </span>
      <span class="hidden md:inline text-[11px] tracking-[0.22em] uppercase border-l border-platinum pl-5" style="color: #101114;">
        Veterinary Academy International
      </span>
    </a>
    <button id="nav-toggle" class="lg:hidden text-navy text-xs tracking-[0.18em] uppercase" aria-label="Menu">Menu</button>
  </div>

  <!-- Bottom row: nav items (desktop only) -->
  <nav class="hidden lg:flex border-t border-platinum-soft/70">
    <div class="container-prose flex items-center justify-center gap-x-7 xl:gap-x-9 py-4 text-[12px] xl:text-[12.5px] tracking-[0.13em] uppercase text-graphite">
      {links.map((l) => (
        <a href={l.href} class="whitespace-nowrap hover:text-navy transition-colors">{l.label}</a>
      ))}
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden lg:hidden border-t border-platinum-soft">
    <nav class="container-prose flex flex-col gap-3 py-6 text-sm tracking-[0.1em] uppercase text-graphite">
      {links.map((l) => (
        <a href={l.href} class="hover:text-navy">{l.label}</a>
      ))}
    </nav>
  </div>
</header>
<script>
  const t = document.getElementById('nav-toggle');
  const m = document.getElementById('nav-mobile');
  t?.addEventListener('click', () => m?.classList.toggle('hidden'));
</script>
