---
const links = [
  { href: '/about', label: 'About' },
  { href: '/programmes', label: 'Programmes' },
  { href: '/veterinary-longevity', label: 'Veterinary Longevity' },
  { href: '/faculty', label: 'Faculty' },
  { href: '/academic-standards', label: 'Academic Standards' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="border-b border-platinum-soft bg-paper">
  <div class="container-prose flex items-center justify-between py-6">
    <a href="/" class="flex items-baseline gap-3">
      <span class="font-serif text-2xl tracking-[0.2em] text-navy-deep uppercase">VAI</span>
      <span class="hidden md:inline text-[11px] tracking-[0.22em] uppercase text-muted">Veterinary Academy International</span>
    </a>
    <nav class="hidden lg:flex items-center gap-7 text-[12.5px] tracking-[0.12em] uppercase text-graphite">
      {links.map((l) => (
        <a href={l.href} class="hover:text-navy transition-colors">{l.label}</a>
      ))}
    </nav>
    <button id="nav-toggle" class="lg:hidden text-navy text-xs tracking-[0.18em] uppercase" aria-label="Menu">Menu</button>
  </div>
  <div id="nav-mobile" class="hidden lg:hidden border-t border-platinum-soft">
    <nav class="container-prose flex flex-col gap-3 py-6 text-sm tracking-[0.1em] uppercase text-graphite">
      {links.map((l) => (
        <a href={l.href} class="hover:text-navy">{l.label}</a>
      ))}
    </nav>
  </div>
</header>
<script>
  const t = document.getElementById('nav-toggle');
  const m = document.getElementById('nav-mobile');
  t?.addEventListener('click', () => m?.classList.toggle('hidden'));
</script>
