---
type NavLink = { href: string; label: string };
type NavItem = NavLink | { label: string; children: NavLink[] };
const items: NavItem[] = [
  { label: 'Home', children: [
    { href: '/', label: 'Home' },
    { href: '/about', label: 'About' },
  ] },
  { href: '/programmes', label: 'Programmes' },
  { href: '/academic-standards', label: 'Academic Standards' },
  { href: '/faculty', label: 'Faculty' },
  { href: '/cpd-ce-alignment', label: 'CPD/CE' },
  { href: '/contact', label: 'Contact' },
];

const lmsUrl = import.meta.env.PUBLIC_LMS_URL ?? 'https://learn.vai.vet/login';
const lmsEnabled = import.meta.env.PUBLIC_LMS_ENABLED === 'true';
---
<header class="border-b border-platinum-soft bg-paper">
  <!-- Top row: logo + tagline (centered on desktop, left on mobile) + mobile menu button -->
  <div class="container-prose flex items-center justify-between lg:justify-center py-6 lg:py-8">
    <a href="/" class="flex flex-col md:flex-row md:items-center gap-1.5 md:gap-5">
      <span class="relative inline-block self-start">
        <img
          src="/vai-logo.svg"
          alt="VAI · Veterinary Academy International"
          class="h-12 md:h-14 w-auto"
        />
        <span class="absolute top-0 -right-3 text-[10px] font-sans" style="color: #101114; line-height: 1;">™</span>
      </span>
      <span class="text-[9.5px] md:text-[11px] tracking-[0.22em] uppercase md:border-l md:border-platinum md:pl-5 leading-tight" style="color: #101114;">
        Veterinary Academy International
      </span>
    </a>
    <button id="nav-toggle" class="lg:hidden text-navy text-xs tracking-[0.18em] uppercase" aria-label="Menu">Menu</button>
  </div>

  <!-- Bottom row: nav items (desktop only) -->
  <nav class="hidden lg:block border-t border-platinum-soft/70">
    <div class="container-prose grid grid-cols-[1fr_auto_1fr] items-center py-4 text-[12px] xl:text-[12.5px] tracking-[0.13em] uppercase text-graphite">
      <div></div>
      <div class="flex items-center justify-center gap-x-7 xl:gap-x-9">
        {items.map((it) => (
          'children' in it ? (
            <div class="nav-group relative" data-nav-group>
              <button type="button" class="nav-trigger whitespace-nowrap hover:text-navy transition-colors inline-flex items-center gap-1.5 uppercase tracking-[0.13em] xl:tracking-[0.13em] text-[12px] xl:text-[12.5px] cursor-pointer" aria-haspopup="true" aria-expanded="false">
                {it.label}
                <svg class="w-2.5 h-2.5 opacity-60 transition-transform" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M1 1l4 4 4-4"/></svg>
              </button>
              <div class="nav-submenu absolute left-1/2 -translate-x-1/2 top-full pt-3 min-w-[11rem] opacity-0 invisible transition-opacity z-50">
                <div class="bg-paper border border-platinum-soft shadow-sm py-2">
                  {it.children.map((c) => (
                    <a href={c.href} class="block whitespace-nowrap px-5 py-2 text-graphite hover:text-navy hover:bg-platinum-soft/40 transition-colors">{c.label}</a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={it.href} class="whitespace-nowrap hover:text-navy transition-colors">{it.label}</a>
          )
        ))}
      </div>
      <div class="flex justify-end">
        {lmsEnabled && (
          <a
            href={lmsUrl}
            rel="noopener noreferrer"
            aria-label="Student login — opens the VAI Learning Management System"
            class="inline-block whitespace-nowrap border border-navy text-navy hover:bg-navy hover:text-ivory transition-colors px-4 py-2 text-[11px] xl:text-[11.5px] tracking-[0.16em] uppercase focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy"
          >Login</a>
        )}
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden lg:hidden border-t border-platinum-soft">
    <nav class="container-prose flex flex-col gap-3 py-6 text-sm tracking-[0.1em] uppercase text-graphite">
      {items.map((it) => (
        'children' in it ? (
          <>
            <div class="text-muted text-xs tracking-[0.18em]">{it.label}</div>
            {it.children.map((c) => (
              <a href={c.href} class="pl-5 hover:text-navy">{c.label}</a>
            ))}
          </>
        ) : (
          <a href={it.href} class="hover:text-navy">{it.label}</a>
        )
      ))}
      {lmsEnabled && (
        <a
          href={lmsUrl}
          rel="noopener noreferrer"
          aria-label="Student login — opens the VAI Learning Management System"
          class="mt-4 inline-block text-center border border-navy text-navy hover:bg-navy hover:text-ivory transition-colors px-5 py-3 text-sm tracking-[0.16em] uppercase focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy"
        >Login</a>
      )}
    </nav>
  </div>
</header>
<style>
  .nav-group:hover > .nav-submenu,
  .nav-group.is-open > .nav-submenu {
    opacity: 1;
    visibility: visible;
  }
  .nav-group.is-open .nav-trigger svg {
    transform: rotate(180deg);
  }
</style>
<script>
  const t = document.getElementById('nav-toggle');
  const m = document.getElementById('nav-mobile');
  t?.addEventListener('click', () => m?.classList.toggle('hidden'));

  const groups = document.querySelectorAll<HTMLElement>('[data-nav-group]');
  groups.forEach((g) => {
    const btn = g.querySelector<HTMLButtonElement>('.nav-trigger');
    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = g.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
      groups.forEach((other) => {
        if (other !== g) {
          other.classList.remove('is-open');
          other.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
        }
      });
    });
  });
  document.addEventListener('click', (e) => {
    groups.forEach((g) => {
      if (!g.contains(e.target as Node)) {
        g.classList.remove('is-open');
        g.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      groups.forEach((g) => {
        g.classList.remove('is-open');
        g.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>
