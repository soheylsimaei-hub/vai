---
const year = new Date().getFullYear();
const cols = [
  {
    title: 'Academy',
    links: [
      { href: '/about', label: 'About VAI' },
      { href: '/about/leadership', label: 'Leadership' },
      { href: '/programmes', label: 'Programmes' },
      { href: '/faculty', label: 'Faculty' },
    ],
  },
  {
    title: 'Standards',
    links: [
      { href: '/academic-standards', label: 'Academic Standards' },
      { href: '/certificate-policy', label: 'Certificate Policy' },
      { href: '/cpd-ce-alignment', label: 'CPD/CE Alignment' },
    ],
  },
  {
    title: 'Engage',
    links: [
      { href: '/contact', label: 'Contact' },
      { href: '/faq', label: 'FAQ' },
      { href: 'https://academiaeuropa.com', label: 'Academia Europa', external: true },
    ],
  },
];
---
<footer class="bg-navy-deep text-ivory mt-32">
  <div class="container-prose py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div>
        <img src="/vai-logo.svg" alt="VAI · Veterinary Academy International" class="h-12 w-auto mb-3" style="filter: brightness(0) invert(1);" />
        <div class="text-[11px] tracking-[0.22em] uppercase text-champagne-soft mb-4">Veterinary Academy International</div>
        <p class="text-sm text-platinum leading-relaxed max-w-xs">
          The veterinary academy of Academia Europa. Structured postgraduate veterinary education.
        </p>
      </div>
      {cols.map((c) => (
        <div>
          <div class="eyebrow text-champagne-soft mb-4">{c.title}</div>
          <ul class="space-y-2 text-sm text-platinum">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="hover:text-ivory transition-colors"
                  {...(l.external ? { rel: 'noopener', target: '_blank' } : {})}
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-16 pt-8 border-t border-navy-soft text-xs text-platinum/80 leading-relaxed">
      <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-4 mb-6">
        <div class="text-[11px] tracking-[0.2em] uppercase text-champagne-soft">Flagship Direction</div>
        <a href="https://www.veterinarylongevity.com" rel="noopener" target="_blank" class="text-platinum hover:text-ivory transition-colors">Visit VeterinaryLongevity.com ↗</a>
      </div>
      <p class="max-w-4xl">
        Veterinary Academy International is a specialised academy of Academia Europa, operated by Solex Education Unipessoal LDA, Portugal. Programmes are developed for postgraduate professional education and may be submitted for CPD/CE review where applicable.
      </p>
      <div class="mt-6">© {year} Veterinary Academy International.</div>
    </div>
  </div>
</footer>
