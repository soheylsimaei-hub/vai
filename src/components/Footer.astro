---
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
const cols = [
  {
    title: 'Academy',
    links: [
      { href: '/about', label: 'About VAI' },
      { href: '/about/leadership', label: 'Leadership' },
      { href: '/programmes', label: 'Programmes' },
      { href: '/faculty', label: 'Faculty' },
    ],
  },
  {
    title: 'Standards',
    links: [
      { href: '/academic-standards', label: 'Academic Standards' },
      { href: '/certificate-policy', label: 'Certificate Policy' },
      { href: '/cpd-ce-alignment', label: 'CPD/CE Alignment' },
    ],
  },
  {
    title: 'Engage',
    links: [
      { href: '/contact', label: 'Contact' },
      { href: '/faq', label: 'FAQ' },
      { href: 'https://academiaeuropa.com', label: 'Academia Europa', external: true },
    ],
  },
];
---
<footer class="bg-navy-deep text-ivory">
  <div class="container-prose py-14">
    <!-- Brand bar -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 pb-12 border-b border-navy-soft">
      <a href="/" class="flex items-center gap-5">
        <span class="relative inline-block">
          <img src="/vai-logo.svg" alt="VAI" class="h-10 w-auto" style="filter: brightness(0) invert(1);" />
          <span class="absolute top-0 -right-3 text-[10px] font-sans text-ivory" style="line-height: 1;">™</span>
        </span>
        <span class="text-[11px] tracking-[0.22em] uppercase text-champagne-soft border-l border-navy-soft pl-5">Veterinary Academy International</span>
      </a>
      <div class="text-[11px] tracking-[0.18em] uppercase text-platinum/80">
        Veterinary education by <a href="https://academiaeuropa.com" rel="noopener" class="text-champagne-soft hover:text-ivory">Academia Europa</a>
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pt-14">
      {cols.map((c) => (
        <div>
          <div class="eyebrow text-champagne-soft mb-5">{c.title}</div>
          <ul class="space-y-3 text-sm text-platinum">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="hover:text-ivory transition-colors"
                  {...(l.external ? { rel: 'noopener', target: '_blank' } : {})}
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Legal & flagship strip -->
    <div class="mt-16 pt-8 border-t border-navy-soft">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-8">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 text-[11px] tracking-[0.18em] uppercase">
          <div class="text-champagne-soft">Flagship Direction</div>
          <a href="https://www.veterinarylongevity.com" rel="noopener" target="_blank" class="text-platinum hover:text-ivory transition-colors">Visit VeterinaryLongevity.com ↗</a>
        </div>
        <SocialLinks />
      </div>
      <p class="max-w-4xl text-xs text-platinum/80 leading-relaxed">
        Veterinary Academy International is veterinary education by Academia Europa, operated by Solex Education Unipessoal LDA, Portugal. Programmes are developed for postgraduate professional education and may be submitted for CPD/CE review where applicable.
      </p>
      <div class="mt-6 flex flex-col gap-2 text-xs text-platinum/60">
        <div>© {year} Veterinary Academy International.</div>
        <div>Historical engravings courtesy of the <a href="https://wellcomecollection.org" rel="noopener" target="_blank" class="hover:text-ivory">Wellcome Collection</a>, London. <a href="https://creativecommons.org/licenses/by/4.0/" rel="noopener" target="_blank" class="hover:text-ivory">CC BY 4.0</a>.</div>
      </div>
    </div>
  </div>
</footer>
